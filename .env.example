# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Elastic Serverless endpoints ---
# Found in: Elastic Cloud console → your project → Connection details
ELASTIC_NODE=https://YOUR_PROJECT.es.REGION.aws.elastic.cloud
KIBANA_NODE=https://YOUR_PROJECT.kb.REGION.aws.elastic.cloud

# --- API Keys ---
# Found in: Kibana → Stack Management → API Keys → Create API key
# Grant superuser or at minimum: index, create_index, cluster:monitor
ELASTIC_API_KEY=your_elasticsearch_api_key_here
KIBANA_API_KEY=your_kibana_api_key_here

# --- Required for serverless ---
SERVERLESS=true

# --- Optional overrides ---
# EVENT_INDEX=logs-testlogs-default
# EVENT_DATE_OFFSET_HOURS=0
# LOG_LEVEL=info
